---
import BaseLayout from "../layouts/BaseLayout.astro";
import { productFeatures } from "../data";
---

<BaseLayout title="功能介绍 - 如是我闻 Rushi">
  <section class="page-hero">
    <span class="eyebrow">功能介绍</span>
    <h1>服务中文录音转写与校对</h1>
    <p>Rushi 把项目管理、本机转写、波形校对、智能改稿和交付导出放进同一个桌面应用。</p>
  </section>
  <section class="section-block">
    <div class="feature-grid wide">
      {productFeatures.map((feature) => (
        <article class="feature-card">
          <h3>{feature.name}</h3>
          <p>{feature.shortDescription}</p>
          <a href={feature.docsPath}>查看说明</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
