---
import BaseLayout from "../layouts/BaseLayout.astro";

const changeModules = import.meta.glob("../../changes/*.md", { eager: true });
const changes = Object.values(changeModules) as Array<{
  frontmatter: Record<string, string>;
  compiledContent: () => string;
}>;
const sorted = changes.sort((a, b) =>
  String(b.frontmatter.date).localeCompare(String(a.frontmatter.date)),
);
---

<BaseLayout title="更新记录 - 如是我闻 Rushi">
  <section class="page-hero">
    <span class="eyebrow">更新记录</span>
    <h1>发行进展与可下载版本</h1>
    <p>
      面向用户的主要变化记在此。当前公开安装包以
      <a href="https://updates.rushi.app/latest.json">updates.rushi.app/latest.json</a>
      为准；条目来自仓库 <code>changes/*.md</code>，并对照主仓
      <a href="https://github.com/Abe-Junwei/rushi">Abe-Junwei/rushi</a> 同步。
    </p>
  </section>
  <section class="section-block">
    <div class="release-list">
      {sorted.map((change) => (
        <article class="release-card">
          <div>
            <strong>{change.frontmatter.title}</strong>
            <span>{change.frontmatter.date}</span>
          </div>
          <div set:html={change.compiledContent()} />
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
