---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { wrapDocSections } from "../../lib/wrapDocSections";

export async function getStaticPaths() {
  const pageModules = import.meta.glob("../../../docs/**/*.md", { eager: true });
  return Object.entries(pageModules).map(([path, page]) => {
    const file = path.split("../../../docs/")[1].replace(/\.md$/, "");
    return {
      params: { slug: file.replace(/\\/g, "/") },
      props: { page },
    };
  });
}

const { page } = Astro.props as {
  page: {
    frontmatter: {
      title: string;
      description?: string;
      foldSections?: boolean;
    };
    compiledContent: () => string | Promise<string>;
  };
};

const rawHtml = await page.compiledContent();
const foldSections = page.frontmatter.foldSections !== false;
const html = foldSections ? wrapDocSections(rawHtml) : rawHtml;
---

<BaseLayout title={`${page.frontmatter.title} - 如是我闻 Rushi`} description={page.frontmatter.description}>
  <section class="doc-page">
    <article class="doc-content">
      <div class="doc-body" set:html={html} />
    </article>
  </section>
</BaseLayout>
