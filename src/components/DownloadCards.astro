---
import { downloads, type DownloadAsset } from "../data";

interface Props {
  items?: DownloadAsset[];
}

const { items = downloads } = Astro.props;
---

<div class="download-panels">
  {
    items.map((item) => (
      <article class="download-panel">
        <div class="download-panel-head">
          <h3>{item.platform}</h3>
          {item.recommended && <span class="download-badge">推荐</span>}
        </div>
        <p class="download-panel-title">{item.title}</p>
        <p class="download-panel-meta">{item.meta}</p>
        <a class="button primary download-panel-action" href={item.href}>
          {item.actionLabel}
        </a>
        <a class="download-checksum" href={item.checksum}>SHA256 校验文件</a>
        <small>{item.note}</small>
      </article>
    ))
  }
</div>
